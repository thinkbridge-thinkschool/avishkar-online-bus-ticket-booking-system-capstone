{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "value": "busbooking"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "environment": {
      "value": "${AZURE_ENV_NAME}"
    },
    "sqlAdminLogin": {
      "value": "sqladmin"
    },
    "sqlAdminPassword": {
      "value": "${SQL_ADMIN_PASSWORD}"
    },
    "sqlAdminPrincipalId": {
      "value": "${SQL_ADMIN_PRINCIPAL_ID}"
    },
    "sqlAdminPrincipalName": {
      "value": "${AZURE_PRINCIPAL_NAME}"
    },
    "tenantId": {
      "value": "${AZURE_TENANT_ID}"
    },
    "aadClientId": {
      "value": "${AAD_CLIENT_ID}"
    },
    "serviceBusSkuOverride": {
      "value": "${SERVICE_BUS_SKU_OVERRIDE}"
    }
  }
}
